# .env.example

# Flask Configuration Variables
# This is a sample environment variable file for Flask backend configuration.

# The secret key for the Flask application. You should generate a strong random key.
SECRET_KEY='your-secret-key-here'

# Environment setting: development or production
FLASK_ENV=development

# Database URL for connecting to the database.
# Replace this with your actual database URL, e.g., postgres://user:password@localhost/dbname
DATABASE_URL='your-database-url-here'

# Additional configuration variables

# Host and port the Flask application runs on
HOST='127.0.0.1'
PORT='5000'

# Debug mode (True or False)
DEBUG=True

# Other environment-specific variables
# Example: Email settings, third-party API keys, etc.
# EMAIL_USER='your-email@example.com'
# EMAIL_PASSWORD='your-email-password'
# API_KEY='your-api-key'
